# Copy to .env (gitignored) before running scripts. All values below are
# defaults produced by `supabase start` and are safe to commit; the real
# secret is the RS256 private key, which lives in supabase/signing_keys.json.

# Local PostgREST base URL (printed by `supabase status`).
SUPABASE_URL=http://127.0.0.1:54321

# Path to the JWKS-style signing keys file the CLI uses for local Auth.
SUPABASE_SIGNING_KEYS_PATH=./supabase/signing_keys.json

# `iss` claim that local Supabase Auth emits and PostgREST accepts.
SUPABASE_JWT_ISS=http://127.0.0.1:54321/auth/v1

# Fixture user UUIDs that match the seed.
USER_A_ID=00000000-0000-0000-0000-0000000000aa
USER_B_ID=00000000-0000-0000-0000-0000000000bb
USER_ORPHAN_ID=00000000-0000-0000-0000-0000000000cc

# The default anon JWT printed by `supabase status`. Filled in by the
# `pnpm verify` script automatically via `supabase status -o env`, so
# you usually don't need to set it manually.
# SUPABASE_ANON_KEY=
